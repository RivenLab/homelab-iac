ETCD_NAME="etcd{{ node_id }}"
ETCD_DATA_DIR="/var/lib/etcd"
ETCD_LISTEN_PEER_URLS="https://{{ ansible_host }}:2380"
ETCD_LISTEN_CLIENT_URLS="https://{{ ansible_host }}:2379,https://127.0.0.1:2379"
ETCD_INITIAL_CLUSTER="{% for host in groups['postgres_cluster_hosts'] %}etcd{{ loop.index }}=https://{{ hostvars[host]['ansible_host'] }}:2380{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_INITIAL_ADVERTISE_PEER_URLS="https://{{ ansible_host }}:2380"
ETCD_ADVERTISE_CLIENT_URLS="https://{{ ansible_host }}:2379"
ETCD_INITIAL_CLUSTER_TOKEN="etcd-cluster-01"
ETCD_INITIAL_CLUSTER_STATE="new"
ETCD_ELECTION_TIMEOUT="5000"
ETCD_HEARTBEAT_INTERVAL="1000"
ETCD_AUTO_COMPACTION_RETENTION="1"
ETCD_INITIAL_ELECTION_TICK_ADVANCE="false"
ETCD_CERT_FILE="/etc/etcd/tls/server.crt"
ETCD_KEY_FILE="/etc/etcd/tls/server.key"
ETCD_TRUSTED_CA_FILE="/etc/etcd/tls/ca.crt"
ETCD_PEER_CERT_FILE="/etc/etcd/tls/server.crt"
ETCD_PEER_KEY_FILE="/etc/etcd/tls/server.key"
ETCD_PEER_TRUSTED_CA_FILE="/etc/etcd/tls/ca.crt"
ETCD_PEER_CLIENT_CERT_AUTH="false"
ETCD_CLIENT_CERT_AUTH="true"