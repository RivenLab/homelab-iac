# vip-manager configuration for Patroni cluster
# Generated by Ansible - do not edit manually

interval: {{ vip_manager_interval | default(1000) }}

trigger-key: "{{ vip_manager_trigger_key | default('/service/' + patroni_scope + '/leader') }}"
trigger-value: "{{ inventory_hostname }}"

ip: {{ vip_manager_vip }}
netmask: {{ vip_manager_netmask }}
interface: {{ vip_manager_interface }}

hosting-type: basic

dcs-type: etcd

dcs-endpoints:
{% for host in groups['postgres_cluster_hosts'] %}
  - https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port | default(2379) }}
{% endfor %}

etcd-ca-file: /etc/patroni/certs/etcd-ca.crt
etcd-cert-file: /etc/patroni/certs/etcd-client.crt
etcd-key-file: /etc/patroni/certs/etcd-client.key

retry-num: {{ vip_manager_retry_num | default(2) }}
retry-after: {{ vip_manager_retry_after | default(250) }}

verbose: false
