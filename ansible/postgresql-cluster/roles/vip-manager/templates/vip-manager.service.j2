[Unit]
Description=Manages Virtual IP for Patroni
After=network-online.target
Before=patroni.service

[Service]
Type=simple

ExecStart=/usr/bin/vip-manager --config=/etc/patroni/vip-manager.yml

# VIP not released when service stopped
# https://github.com/cybertec-postgresql/vip-manager/issues/19
ExecStopPost=/sbin/ip addr del {{ vip_manager_vip }}/{{ vip_manager_netmask }} dev {{ vip_manager_interface }}

Restart=on-failure

[Install]
WantedBy=multi-user.target
