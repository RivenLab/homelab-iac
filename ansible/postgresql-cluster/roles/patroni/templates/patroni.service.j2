[Unit]
Description=Patroni Daemon
After=syslog.target network.target etcd.service

[Service]
Type=simple
User=postgres
Group=postgres
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStartPre=/bin/mkdir -p /var/log/patroni
ExecStartPre=/bin/chown postgres:postgres /var/log/patroni
ExecStart=/usr/bin/patroni /etc/patroni/patroni.yml
KillMode=process
TimeoutSec=30
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target