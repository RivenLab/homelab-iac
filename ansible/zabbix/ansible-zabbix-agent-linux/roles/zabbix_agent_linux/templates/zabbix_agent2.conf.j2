# Zabbix Agent 2 Configuration
# Generated by Ansible - do not edit manually

############################
# Identity / Active Checks #
############################
Hostname={{ zabbix_agent_hostname }}
ServerActive={{ zabbix_agent_server_active }}:{{ zabbix_agent_server_active_port }}

##################
# Runtime / Files #
##################
PidFile={{ zabbix_agent_pid_file }}
LogFile={{ zabbix_agent_log_file }}
LogFileSize={{ zabbix_agent_log_file_size }}

####################
# Network / Checks #
####################
ListenPort={{ zabbix_agent_listen_port }}
Timeout={{ zabbix_agent_timeout | default(20) }}

# Passive checks source(s)
{% if zabbix_agent_server | default('') | length > 0 %}
Server={{ zabbix_agent_server }}
{% endif %}

###########
# Sockets #
###########
PluginSocket={{ zabbix_agent_plugin_socket }}
ControlSocket={{ zabbix_agent_control_socket }}

#############
# TLS / PSK #
#############
{% if zabbix_agent_tls_mode | default('unencrypted') == 'psk' %}
TLSConnect={{ zabbix_agent_tls_connect }}
TLSAccept={{ zabbix_agent_tls_accept }}
TLSPSKIdentity={{ zabbix_agent_tls_psk_identity }}
TLSPSKFile={{ zabbix_agent_tls_psk_file }}
{% endif %}

############
# Includes #
############
Include={{ zabbix_agent_config_dir }}/plugins.d/*.conf
Include={{ zabbix_agent_config_dir }}/*.conf
