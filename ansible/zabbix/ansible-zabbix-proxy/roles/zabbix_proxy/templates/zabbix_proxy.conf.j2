# Zabbix Proxy Configuration
# Generated by Ansible

### MANDATORY PARAMETERS
Hostname={{ zabbix_proxy_hostname }}
Server={{ zabbix_proxy_server }}:{{ zabbix_proxy_server_port }}
ProxyMode={{ zabbix_proxy_mode }}

### DATABASE
{% if zabbix_db_type | lower == "sqlite" %}
DBName={{ zabbix_db_sqlite_path }}/{{ zabbix_db_sqlite_file }}
{% else %}
DBHost={{ zabbix_db_host }}
DBName={{ zabbix_db_name }}
DBUser={{ zabbix_db_user }}
DBPassword={{ zabbix_db_password }}
DBPort={{ zabbix_db_port }}
{% endif %}

### LOGGING
LogFile={{ zabbix_proxy_log_file }}
LogFileSize={{ zabbix_proxy_log_size }}
DebugLevel=3

### PERFORMANCE
StartPollers={{ zabbix_proxy_startpollers }}
DataSenderFrequency={{ zabbix_proxy_datasender_frequency }}
CacheSize={{ zabbix_proxy_cache_size }}
HistoryCacheSize={{ zabbix_proxy_history_cache_size }}

### BASIC SETTINGS
ListenPort=10051
PidFile=/var/run/zabbix/zabbix_proxy.pid
SocketDir=/var/run/zabbix
Timeout=30
StatsAllowedIP=127.0.0.1